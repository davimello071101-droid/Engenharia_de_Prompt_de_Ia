        "# desenvolver um sistema que consulte uma API pública (Via Cep) e retorne as informações de endereços formatadas de forma legível. Inclua tratamento de exceções try except\n",
        "\n",
        "import requests # Importa a biblioteca requests para fazer requisições HTTP\n",
        "\n",
        "def consultar_cep(cep):\n",
        "    \"\"\"\n",
        "    Consulta a API ViaCEP para obter informações de endereço a partir de um CEP.\n",
        "    Inclui tratamento de exceções para erros de rede, CEPs inválidos, etc.\n",
        "    Retorna um dicionário com os dados do endereço ou uma mensagem de erro.\n",
        "    \"\"\"\n",
        "    # Remove quaisquer caracteres não numéricos do CEP\n",
        "    cep = ''.join(filter(str.isdigit, cep))\n",
        "\n",
        "    # Verifica se o CEP tem 8 dígitos\n",
        "    if len(cep) != 8:\n",
        "        return {\"erro\": \"CEP inválido: O CEP deve conter 8 dígitos numéricos.\"}\n",
        "\n",
        "    # URL da API ViaCEP\n",
        "    url = f\"https://viacep.com.br/ws/{cep}/json/\"\n",
        "\n",
        "    try:\n",
        "        # Faz a requisição HTTP para a API\n",
        "        response = requests.get(url)\n",
        "        response.raise_for_status()  # Levanta uma exceção para erros HTTP (4xx ou 5xx)\n",
        "\n",
        "        # Converte a resposta JSON para um dicionário Python\n",
        "        dados_cep = response.json()\n",
        "\n",
        "        # Verifica se a API retornou erro (CEP não encontrado, por exemplo)\n",
        "        if \"erro\" in dados_cep and dados_cep[\"erro\"]:\n",
        "            return {\"erro\": \"CEP não encontrado ou inválido na base de dados do ViaCEP.\"}\n",
        "        else:\n",
        "            return dados_cep\n",
        "\n",
        "    except requests.exceptions.HTTPError as err_http:\n",
        "        return {\"erro\": f\"Erro HTTP: {err_http}\"}\n",
        "    except requests.exceptions.ConnectionError as err_conn:\n",
        "        return {\"erro\": f\"Erro de conexão: Verifique sua internet. {err_conn}\"}\n",
        "    except requests.exceptions.Timeout as err_timeout:\n",
        "        return {\"erro\": f\"Tempo limite excedido na requisição: {err_timeout}\"}\n",
        "    except requests.exceptions.RequestException as err:\n",
        "        return {\"erro\": f\"Erro na requisição: {err}\"}\n",
        "    except ValueError:\n",
        "        return {\"erro\": \"Erro ao decodificar a resposta JSON.\"}\n",
        "    except Exception as e:\n",
        "        return {\"erro\": f\"Um erro inesperado ocorreu: {e}\"}\n",
        "\n",
        "def formatar_endereco(dados_cep):\n",
        "    \"\"\"\n",
        "    Formata as informações de endereço para exibição legível.\n",
        "    \"\"\"\n",
        "    if \"erro\" in dados_cep:\n",
        "        return f\"Ocorreu um erro: {dados_cep['erro']}\"\n",
        "    else:\n",
        "        endereco_formatado = f\"\"\"\n",
        "Endereço Encontrado:\n",
        "--------------------\n",
        "CEP:        {dados_cep.get('cep', 'N/A')}\n",
        "Logradouro: {dados_cep.get('logradouro', 'N/A')}\n",
        "Complemento: {dados_cep.get('complemento', 'N/A')}\n",
        "Bairro:     {dados_cep.get('bairro', 'N/A')}\n",
        "Localidade: {dados_cep.get('localidade', 'N/A')} - {dados_cep.get('uf', 'N/A')}\n",
        "IBGE:       {dados_cep.get('ibge', 'N/A')}\n",
        "GIA:        {dados_cep.get('gia', 'N/A')}\n",
        "DDD:        {dados_cep.get('ddd', 'N/A')}\n",
        "SIAFI:      {dados_cep.get('siafi', 'N/A')}\n",
        "\"\"\"\n",
        "        return endereco_formatado\n",
        "\n",
        "# --- Uso interativo ---\n",
        "print(\"\\n--- Consultar CEP ---\")\n",
        "cep_digitado = input(\"Digite o CEP que deseja consultar (ou 'sair' para finalizar): \")\n",
        "\n",
        "while cep_digitado.lower() != 'sair':\n",
        "    dados = consultar_cep(cep_digitado)\n",
        "    print(formatar_endereco(dados))\n",
        "    cep_digitado = input(\"Digite outro CEP (ou 'sair' para finalizar): \")\n",
        "\n"
      ],
