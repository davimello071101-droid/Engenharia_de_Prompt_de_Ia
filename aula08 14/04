        "open(os.path.join(DIRETORIO_TESTE, 'script.py'), 'w').close()\n",
        "open(os.path.join(DIRETORIO_TESTE, 'arquivo_sem_extensao'), 'w').close()\n",
        "open(os.path.join(DIRETORIO_TESTE, 'outro_arquivo.txt'), 'w').close()\n",
        "\n",
        "print(f\"Arquivos de teste criados em '{DIRETORIO_TESTE}'.\")\n",
        "print(\"Conteúdo antes da organização:\")\n",
        "print(os.listdir(DIRETORIO_TESTE))\n",
        "\n",
        "# Chamar a função para organizar\n",
