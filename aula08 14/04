        "import time\n",
        "import random\n",
        "\n",
        "class Monitor:\n",
        "    def __init__(self, limite_critico, intervalo_monitoramento_segundos):\n",
        "        self.limite_critico = limite_critico\n",
        "        self.intervalo_monitoramento_segundos = intervalo_monitoramento_segundos\n",
        "        print(\"Iniciando monitoramento autônomo...\")\n",
        "        print(f\"Limite crítico definido em: {self.limite_critico}\")\n",
        "\n",
        "    def _simular_condicao_monitorada(self):\n",
        "        # Simula a leitura de um valor (e.g., temperatura, nível de estoque)\n",
        "        return random.uniform(0, 100)\n",
        "\n",
        "    def _verificar_e_alertar(self, valor_atual, alertar_por_email=False):\n",
        "        if valor_atual > self.limite_critico:\n",
        "            mensagem = f\"ALERTA CRÍTICO: O valor atual ({valor_atual:.2f}) excedeu o limite ({self.limite_critico:.2f})!\"\n",
        "            print(mensagem) # Alerta no console\n",
        "            if alertar_por_email:\n",
        "                print(f\"[E-MAIL SIMULADO] Enviando e-mail para administradores: {mensagem}\")\n",
        "        else:\n",
        "            print(f\"Condição normal: Valor atual = {valor_atual:.2f}\")\n",
        "\n",
        "    def run(self):\n",
        "        try:\n",
        "            while True:\n",
        "                valor_monitorado = self._simular_condicao_monitorada()\n",
        "                self._verificar_e_alertar(valor_monitorado, alertar_por_email=True)\n",
        "                time.sleep(self.intervalo_monitoramento_segundos)\n",
        "        except KeyboardInterrupt:\n",
        "            print(\"Monitoramento interrompido pelo usuário.\")\n",
        "\n",
        "# --- Configurações do monitoramento ---\n",
        "LIMITE_CRITICO = 80.0\n",
        "INTERVALO_MONITORAMENTO_SEGUNDOS = 5\n",
        "\n",
        "# Cria uma instância do monitor e o executa\n",
        "monitor_sistema = Monitor(LIMITE_CRITICO, INTERVALO_MONITORAMENTO_SEGUNDOS)\n",
        "monitor_sistema.run()\n"
      ],
